# --- Polygon (shared with batch pipeline) ---
POLYGON_API_KEY=YOUR_API_KEY

# --- Batch pipeline access (used by seed_security_master.py to pull SCD2) ---
GOOGLE_CLOUD_PROJECT=GOOGLE_CLOUD_PROJECT
BQ_DATASET_ID=BIG_QUERY_DATASET_ID
GOOGLE_APPLICATION_CREDENTIALS=PATH_TO_CREDENTIALS_JSON

# --- Confluent Cloud (Kafka) ---
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.region.provider.confluent.cloud:9092
KAFKA_SASL_USERNAME=CLUSTER_API_KEY
KAFKA_SASL_PASSWORD=CLUSTER_API_SECRET
KAFKA_TOPIC_AGGREGATES=market.aggregates
# Reserved for a future Polygon plan upgrade (Advanced+):
# KAFKA_TOPIC_TRADES=market.trades
# KAFKA_TOPIC_QUOTES=market.quotes

# --- Databricks (only needed if invoking jobs from local CLI; notebooks run server-side) ---
DATABRICKS_HOST=https://dbc-xxxxxxxx-xxxx.cloud.databricks.com
DATABRICKS_TOKEN=DAPIxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Snowflake (recon target) — key-pair auth (MFA-safe; see README) ---
SNOWFLAKE_ACCOUNT=myorg-ab12345
SNOWFLAKE_USER=SVC_STREAMING
# Provide the private key as EITHER a file path (local/server) ...
SNOWFLAKE_PRIVATE_KEY_PATH=C:/path/to/rsa_key.p8
# ... OR inline PEM text (single env var; useful for Streamlit Cloud / CI):
# SNOWFLAKE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Only if the key is encrypted:
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=...
SNOWFLAKE_ROLE=STREAMING_ROLE
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=MARKET_STREAMING
SNOWFLAKE_SCHEMA=GOLD
