# Local secrets template — copy to .streamlit/secrets.toml and fill in.
# On Streamlit Community Cloud, paste the same TOML into
# App settings → Secrets (no file needed in the repo).
#
# .streamlit/secrets.toml is git-ignored.

[snowflake]
SNOWFLAKE_ACCOUNT   = "myorg-ab12345"
SNOWFLAKE_USER      = "SVC_STREAMING"
# Paste the full PEM private key. In TOML, a multi-line literal uses triple quotes:
SNOWFLAKE_PRIVATE_KEY = """
-----BEGIN PRIVATE KEY-----
MIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQ...
-----END PRIVATE KEY-----
"""
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE = "..."   # only if the key is encrypted
SNOWFLAKE_WAREHOUSE = "COMPUTE_WH"
SNOWFLAKE_ROLE      = "STREAMING_ROLE"      # optional
